generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id           String  @id @default(uuid())
  name         String
  email        String  @unique
  password     String
  refreshToken String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  @@index([createdAt])
  @@index([name, createdAt])
  @@map("admins")
}

// Users (Global Identity)
model User {
  id             String   @id @default(uuid())
  firstName      String
  lastName       String
  email          String   @unique
  password       String?
  refreshToken   String?
  isActive       Boolean  @default(false)
  role           Role?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  profilePicture String?

  // Relationships
  testimonials       Testimonial[]
  salonUsers         SalonUser[]
  ownerProfile       OwnerProfile?
  employeeProfile    EmployeeProfile?
  accountantProfile  AccountantProfile?
  mainAppointments   Appointment[]      @relation("MainClient")
  participantEntries Participant[]
  voucherPurchases   VoucherPurchase[]
  contactMessages    ContactMessage[]
  receipts           Receipt[]
  appointmentLogs    AppointmentLog[]
  paymentLogs        PaymentLog[]

  @@index([email])
}

// Role Enum (Platform / Tenant roles)
enum Role {
  SUPER_ADMIN
  SALON_OWNER
  EMPLOYEE
  ACCOUNTANT
  CLIENT
}

// Salon (Tenant)
enum SalonStatus {
  ACTIVE
  TRIAL
  CANCELLED
  LEADS
  EXPIRED
}

enum PlanType {
  BASIC
  PREMIUM
  ENTERPRISE
}

model Salon {
  id            String @id @default(uuid())
  name          String
  businessType  String
  vtaNumber     String @unique
  employeeCount Int
  email         String @unique
  phoneNumber   String

  country  String
  province String
  city     String
  zipCode  String

  status       SalonStatus @default(TRIAL)
  plan         PlanType    @default(BASIC)
  trialEndsAt  DateTime?
  revenue      Decimal?    @db.Decimal(12, 2)
  ltv          Decimal?    @db.Decimal(12, 2)
  supportCount Int         @default(0)
  lastActiveAt DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  createdBy String?
  updatedBy String?

  owners             OwnerProfile[]
  employeeProfiles   EmployeeProfile[]
  accountantProfiles AccountantProfile[]

  salonUsers       SalonUser[]
  services         Service[]
  testimonials     Testimonial[]
  appointments     Appointment[]
  vouchers         Voucher[]
  voucherPurchases VoucherPurchase[]
  contactMessages  ContactMessage[]
  receipts         Receipt[]
  bundles          Bundle[]
  appointmentLogs  AppointmentLog[]
  payslips         Payslip[]
  paymentLogs      PaymentLog[]
  shifts           Shift[]

  @@index([status])
  @@index([plan])
  @@index([country])
  @@index([province])
  @@index([city])
  @@index([createdAt])
  @@index([country, province])
}

model SalonUser {
  id        String   @id @default(uuid())
  userId    String
  salonId   String
  role      Role
  phone     String?
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id])
  salon Salon @relation(fields: [salonId], references: [id])

  @@unique([userId, salonId])
}

model Testimonial {
  id String @id @default(uuid())

  salonId String
  salon   Salon  @relation(fields: [salonId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  comment String
  rating  Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([salonId])
  @@index([userId])
}

model Service {
  id      String @id @default(uuid())
  salonId String
  salon   Salon  @relation(fields: [salonId], references: [id], onDelete: Cascade)

  serviceName String
  categories  String[]

  duration     Int
  postBreakMin Int

  price Decimal @db.Decimal(10, 2)
  vat   Decimal @db.Decimal(5, 2)

  description String?
  icon        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employees           ServiceEmployee[]
  appointmentServices AppointmentService[]
  bundleServices      BundleService[]

  @@index([salonId])
}

model ServiceEmployee {
  id String @id @default(uuid())

  serviceId  String
  employeeId String

  service  Service         @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  employee EmployeeProfile @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([serviceId, employeeId])
}

model OwnerProfile {
  id             String    @id @default(uuid())
  userId         String    @unique
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  invitationSent Boolean   @default(false)
  deletedAt      DateTime?

  salonId String
  salon   Salon  @relation(fields: [salonId], references: [id], onDelete: Cascade)
}

enum ProfileStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

model EmployeeProfile {
  id      String @id @default(uuid())
  userId  String @unique
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  salonId String
  salon   Salon  @relation(fields: [salonId], references: [id], onDelete: Cascade)

  phone  String?
  gender String?
  age    Int?

  salary           Decimal  @db.Decimal(10, 2)
  designation      String
  dob              String
  address          String
  city             String
  province         String
  cap              String
  emcName          String?
  emcNumber        String?
  contractType     String
  taxIdCode        String
  iban             String?
  startDate        DateTime
  endDate          DateTime
  remunerationType String

  certifications   String[] @default([])
  completedCourses String[] @default([])

  languages         EmployeeLanguage[]
  socialConnections SocialConnection[]

  directManagerId String?
  directManager   DirectManager? @relation(fields: [directManagerId], references: [id])

  invitationStatus Boolean          @default(true)
  employmentStatus EmploymentStatus @default(PENDING)
  profileStatus    ProfileStatus    @default(PENDING)
  lastActiveAt     DateTime?
  dateOfJoining    DateTime?
  dateOfLeaving    DateTime?
  statusNote       String?
  isDeleted        Boolean          @default(false)
  createdBy        String?
  updatedBy        String?
  lastLoginIp      String?

  yearlyLeaveAllowance Int       @default(20)
  nextEvaluationDate   DateTime?
  contractNetSalary    Decimal?  @db.Decimal(10, 2)

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  services         ServiceEmployee[]
  assignedServices AppointmentService[]
  bundleMembers    BundleMember[]
  timeOffRequests  TimeOffRequest[]
  payslips         Payslip[]
  shifts           Shift[]
}

model Shift {
  id         String          @id @default(uuid())
  salonId    String
  salon      Salon           @relation(fields: [salonId], references: [id], onDelete: Cascade)
  employeeId String
  employee   EmployeeProfile @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  date       DateTime
  totalHours Decimal  @db.Decimal(10, 2)

  intervals ShiftInterval[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([salonId])
  @@index([employeeId])
  @@index([date])
}

model ShiftInterval {
  id      String @id @default(uuid())
  shiftId String
  shift   Shift  @relation(fields: [shiftId], references: [id], onDelete: Cascade)

  startTime String
  endTime   String

  @@index([shiftId])
}

model DirectManager {
  id           String            @id @default(uuid())
  name         String
  lastAccessAt DateTime          @default(now())
  permits      String            @default("All")
  employees    EmployeeProfile[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EmployeeLanguage {
  id         String          @id @default(uuid())
  name       String
  level      String
  employeeId String
  employee   EmployeeProfile @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model SocialConnection {
  id         String          @id @default(uuid())
  platform   String
  status     String          @default("Not Connected")
  employeeId String
  employee   EmployeeProfile @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

enum EmploymentStatus {
  PENDING
  ACTIVE
  ON_LEAVE
  INACTIVE
}

model AccountantProfile {
  id            String    @id @default(uuid())
  userId        String    @unique
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  licenseNumber String?
  deletedAt     DateTime?

  salonId String
  salon   Salon  @relation(fields: [salonId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Appointment {
  id      String @id @default(uuid())
  salonId String
  salon   Salon  @relation(fields: [salonId], references: [id])

  clientId String
  client   User   @relation("MainClient", fields: [clientId], references: [id])

  date   DateTime
  note   String?
  status AppointmentStatus @default(BOOKED)

  participants Participant[]
  receipt      Receipt?
  payment      Payment?
  logs         AppointmentLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([salonId])
  @@index([clientId])
}

model AppointmentLog {
  id            String      @id @default(uuid())
  salonId       String? // Added for faster filtering by Salon
  salon         Salon?      @relation(fields: [salonId], references: [id], onDelete: Cascade)
  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  userId        String?
  user          User?       @relation(fields: [userId], references: [id])

  action    String // e.g., "Appointment Created", "Paid"
  status    AppointmentStatus
  createdAt DateTime          @default(now())

  @@index([salonId])
  @@index([appointmentId])
}

model Participant {
  id            String      @id @default(uuid())
  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  name String

  services AppointmentService[]
}

model AppointmentService {
  id String @id @default(uuid())

  participantId String
  participant   Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  serviceId String
  service   Service @relation(fields: [serviceId], references: [id])

  employeeId String?
  employee   EmployeeProfile? @relation(fields: [employeeId], references: [id])

  priceAtBooking Decimal @db.Decimal(10, 2)

  startAt DateTime
  endAt   DateTime
}

model Payment {
  id String @id @default(uuid())

  appointmentId String?      @unique
  appointment   Appointment? @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  voucherPurchase VoucherPurchase?

  amount   Decimal @db.Decimal(10, 2)
  discount Decimal @default(0) @db.Decimal(10, 2)
  tax      Decimal @default(0) @db.Decimal(10, 2)
  total    Decimal @db.Decimal(10, 2)

  currency String @default("EUR")

  method PaymentMethod
  status PaymentStatus @default(PENDING)

  iban                  String?
  reference             String? @unique
  providerTransactionId String?

  paidAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  receiptId String?  @unique
  receipt   Receipt? @relation(fields: [receiptId], references: [id])

  logs PaymentLog[]
}

enum AppointmentStatus {
  BOOKED
  STARTED
  CONFIRMED
  CANCELLED
  COMPLETED
  ARRIVED
  PAID
}

enum PaymentMethod {
  PAY_IN_SALON
  CARD
  APPLE_PAY
  GOOGLE_PAY
  BANK_TRANSFER
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

model Voucher {
  id String @id @default(uuid())

  salonId String
  salon   Salon  @relation(fields: [salonId], references: [id], onDelete: Cascade)

  title    String
  subtitle String?

  value Decimal @db.Decimal(10, 2)
  price Decimal @db.Decimal(10, 2)

  discountPercent Int?
  description     String?

  validityDays Int

  imageUrl String?
  theme    String?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  purchases VoucherPurchase[]

  @@index([salonId])
  @@index([isActive])
}

model VoucherPurchase {
  id String @id @default(uuid())

  voucherId String
  voucher   Voucher @relation(fields: [voucherId], references: [id], onDelete: Cascade)

  salonId String
  salon   Salon  @relation(fields: [salonId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  code           String  @unique
  senderName     String
  recipientName  String
  recipientEmail String
  message        String?

  expiryDate DateTime
  status     VoucherStatus @default(PENDING)

  paymentId String?  @unique
  payment   Payment? @relation(fields: [paymentId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum VoucherStatus {
  PENDING
  PAID
  CANCELLED
  EXPIRED
}

// -------------------------------------------------------------------------
// CONTACT MESSAGE / SEND MESSAGE TO SALON
// -------------------------------------------------------------------------

model ContactMessage {
  id String @id @default(uuid())

  salonId String
  salon   Salon  @relation(fields: [salonId], references: [id], onDelete: Cascade)

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  name    String
  email   String
  subject String
  message String @db.Text

  status MessageStatus @default(UNREAD)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([salonId])
  @@index([email])
}

enum MessageStatus {
  UNREAD
  READ
  ARCHIVED
  REPLIED
}

// -------------------------------------------------------------------------
// RECEIPT & RECEIPT ITEM
// -------------------------------------------------------------------------

model Receipt {
  id      String @id @default(uuid())
  salonId String
  salon   Salon  @relation(fields: [salonId], references: [id], onDelete: Cascade)

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  appointmentId String?      @unique
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])

  receiptNumber String // e.g., #001
  clientName    String
  clientEmail   String?

  subTotal    Decimal @db.Decimal(12, 2)
  taxAmount   Decimal @db.Decimal(12, 2)
  totalAmount Decimal @db.Decimal(12, 2)

  method        PaymentMethod @default(PAY_IN_SALON)
  status        ReceiptStatus @default(ISSUED)
  isIndependent Boolean       @default(false)

  items   ReceiptItem[]
  payment Payment?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([salonId])
  @@index([receiptNumber])
}

model ReceiptItem {
  id        String  @id @default(uuid())
  receiptId String
  receipt   Receipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)

  description String
  quantity    Int     @default(1)
  unitPrice   Decimal @db.Decimal(12, 2)
  vatRate     Decimal @db.Decimal(5, 2)

  createdAt DateTime @default(now())
}

enum ReceiptStatus {
  DRAFT
  ISSUED
  PAID
  CANCELLED
  REFUNDED
}

// -------------------------------------------------------------------------
// BUNDLES (NEW MODELS)
// -------------------------------------------------------------------------

enum BundleScheduleType {
  BOOKED_IN_SEQUENCE
  BOOKED_IN_PARALLEL
}

enum BundleCategory {
  REGULAR
  PROMOTION
}

enum BundlePriceType {
  FIXED
  PERCENTAGE_DISCOUNT
}

model Bundle {
  id      String @id @default(uuid())
  salonId String
  salon   Salon  @relation(fields: [salonId], references: [id], onDelete: Cascade)

  name        String
  category    BundleCategory @default(REGULAR)
  description String?        @db.Text

  priceType BundlePriceType @default(FIXED)
  price     Decimal         @db.Decimal(10, 2)
  duration  Int

  scheduleType    BundleScheduleType @default(BOOKED_IN_SEQUENCE)
  addToOnlineBook Boolean            @default(true)

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  services BundleService[]
  members  BundleMember[]

  @@index([salonId])
}

model BundleService {
  id        String @id @default(uuid())
  bundleId  String
  serviceId String

  bundle  Bundle  @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([bundleId, serviceId])
}

model BundleMember {
  id         String @id @default(uuid())
  bundleId   String
  employeeId String

  bundle   Bundle          @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  employee EmployeeProfile @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([bundleId, employeeId])
}

model TimeOffRequest {
  id         String          @id @default(uuid())
  employeeId String
  employee   EmployeeProfile @relation(fields: [employeeId], references: [id])

  type      String // e.g., "Annual Leave", "Sick Leave"
  startDate DateTime
  endDate   DateTime
  startTime String? // e.g., "09:00"
  endTime   String? // e.g., "18:00"

  repeat          Boolean          @default(false)
  repeatFrequency RepeatFrequency?

  description String?
  status      String  @default("APPROVED")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum RepeatFrequency {
  DAILY
  WEEKLY
  EVERY_2_WEEKS
  MONTHLY
  QUARTERLY
  YEARLY
}

// -------------------------------------------------------------------------
// REMUNERATION & PAYSLIPS (For Member Remuneration Tab)
// -------------------------------------------------------------------------

model Payslip {
  id         String          @id @default(uuid())
  salonId    String
  salon      Salon           @relation(fields: [salonId], references: [id], onDelete: Cascade)
  employeeId String
  employee   EmployeeProfile @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  date          DateTime // Period end date (e.g., November 29, 2024)
  netAmount     Decimal  @db.Decimal(12, 2) // € 1,700
  grossAmount   Decimal  @db.Decimal(12, 2) // € 2,200
  contributions Decimal  @default(0) @db.Decimal(12, 2)

  // --- AUTOMATED TFR TRACKING ---
  tfrContribution Decimal @db.Decimal(12, 2) // Calculated: Gross / 13.5
  tfrAccumulated  Decimal @db.Decimal(12, 2) // Running total (e.g., € 5,500)

  status      PayslipStatus @default(GENERATED)
  documentUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([salonId])
  @@index([employeeId])
  @@index([date])
}

enum PayslipStatus {
  DRAFT
  GENERATED
  PAID
}

// -------------------------------------------------------------------------
// ACTIVITY & PAYMENT LOGS (Multi-Tenant & Stripe Ready)
// -------------------------------------------------------------------------

model PaymentLog {
  id        String  @id @default(uuid())
  salonId   String
  salon     Salon   @relation(fields: [salonId], references: [id], onDelete: Cascade)
  paymentId String
  payment   Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?   @relation(fields: [userId], references: [id])

  event        String // e.g., "STRIPE_WEBHOOK_RECEIVED"
  action       String // e.g., "Payment authorized via Stripe"
  statusBefore PaymentStatus?
  statusAfter  PaymentStatus

  metadata  Json? // Stores raw provider data (Stripe/Filip)
  createdAt DateTime @default(now())

  @@index([salonId])
  @@index([paymentId])
}
