
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
model Admin {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  password     String
  refreshToken String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("admins")
  @@index([name])
  @@index([createdAt])
  @@index([name, createdAt])
}
// Users (Global Identity)
model User {
  id           String   @id @default(uuid())
  firstName    String
  lastName     String
  email        String   @unique
  password     String?
  refreshToken String?
  isActive     Boolean  @default(false)
  role         Role?    
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  profilePicture String?

  // Relationships
  testimonials Testimonial[] 
  salonUsers        SalonUser[]
  ownerProfile      OwnerProfile?    
  employeeProfile   EmployeeProfile?
  accountantProfile AccountantProfile?
  mainAppointments Appointment[] @relation("MainClient")
  participantEntries Participant[]
  voucherPurchases  VoucherPurchase[]
  contactMessages ContactMessage[]
  receipts Receipt[]
  appointmentLogs   AppointmentLog[]

  @@index([email])
}

// Role Enum (Platform / Tenant roles)
enum Role {
  SUPER_ADMIN
  SALON_OWNER
  EMPLOYEE
  ACCOUNTANT
  CLIENT
}

// Salon (Tenant)
enum SalonStatus {
  ACTIVE
  TRIAL
  CANCELLED
  LEADS
  EXPIRED
}

enum PlanType {
  BASIC
  PREMIUM
  ENTERPRISE
}

model Salon {
  id            String   @id @default(uuid())
  name          String
  businessType  String
  vtaNumber     String   @unique
  employeeCount Int
  email         String   @unique
  phoneNumber   String

  country       String
  province      String
  city          String
  zipCode       String

  status        SalonStatus @default(TRIAL)
  plan          PlanType    @default(BASIC)
  trialEndsAt   DateTime?
  revenue       Decimal?    @db.Decimal(12,2)
  ltv           Decimal?    @db.Decimal(12,2)
  supportCount  Int         @default(0)
  lastActiveAt  DateTime?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?

  createdBy     String?
  updatedBy     String?

  // Relation to owners (OwnerProfile)
  owners        OwnerProfile[]

  // Reverse relations for EmployeeProfile and AccountantProfile
  employeeProfiles EmployeeProfile[]
  accountantProfiles AccountantProfile[]

  salonUsers    SalonUser[]
  services      Service[] 
  testimonials Testimonial[]
  appointments Appointment[]
  vouchers          Voucher[]
  voucherPurchases  VoucherPurchase[]
  contactMessages ContactMessage[]
  receipts        Receipt[]
  bundles         Bundle[]


  @@index([status])
  @@index([plan])
  @@index([country])
  @@index([province])
  @@index([city])
  @@index([createdAt])
  @@index([country, province])
}


// Multi-Tenant Bridge: User ↔ Salon
model SalonUser {
  id        String   @id @default(uuid())
  userId    String
  salonId   String
  role      Role
  phone     String?
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id])
  salon Salon @relation(fields: [salonId], references: [id])

  @@unique([userId, salonId])
}

model Testimonial {
  id        String   @id @default(uuid())

  salonId   String
  salon     Salon    @relation(fields: [salonId], references: [id], onDelete: Cascade)

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  comment   String
  rating    Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([salonId])
  @@index([userId])
}

model Service {
  id           String   @id @default(uuid())
  salonId      String
  salon        Salon    @relation(fields: [salonId], references: [id], onDelete: Cascade)

  serviceName  String
  categories   String[]

  duration     Int
  postBreakMin Int

  price        Decimal  @db.Decimal(10,2)
  vat          Decimal  @db.Decimal(5,2)

  description  String?
  icon         String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  employees    ServiceEmployee[]
  appointmentServices AppointmentService[]
  bundleServices BundleService[]

  @@index([salonId])
}

model ServiceEmployee {
  id         String @id @default(uuid())

  serviceId  String
  employeeId String

  service    Service         @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  employee   EmployeeProfile @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([serviceId, employeeId])
}


// -----------------
// Optional Role Profiles (OwnerProfile, EmployeeProfile, AccountantProfile)
// -----------------

// OwnerProfile should reference the User model and the Salon model
model OwnerProfile {
  id             String   @id @default(uuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  invitationSent Boolean  @default(false)
  deletedAt      DateTime?

  salonId        String  // Reference to the salon the owner belongs to
  salon          Salon   @relation(fields: [salonId], references: [id], onDelete: Cascade) // Reverse relation to Salon
}

enum ProfileStatus {
  PENDING   // Profile created but not fully activated
  ACTIVE    // Profile fully active
  SUSPENDED // Optional future use
}

// -------------------------------------------------------------------------
// NEW MODEL: Direct Manager (To handle the Manager UI section)
// -------------------------------------------------------------------------
model EmployeeProfile {
  id               String   @id @default(uuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  salonId          String
  salon            Salon    @relation(fields: [salonId], references: [id], onDelete: Cascade)

  // --- [NEW] Personal Data ---
  phone            String?
  gender           String?   
  age              Int?      

  // --- [EXISTING] Employment Data (UNCHANGED) ---
  salary           Decimal   @db.Decimal(10, 2)
  designation      String
  dob              String
  address          String
  city             String
  province         String
  cap              String
  emcName          String?
  emcNumber        String?
  contractType     String
  taxIdCode        String
  iban             String?
  startDate        DateTime
  endDate          DateTime
  remunerationType String

  // --- [NEW] Additional Professional Data ---
  certifications   String[]  @default([])
  completedCourses String[]  @default([])
  
  languages        EmployeeLanguage[]
  socialConnections SocialConnection[]

  // --- [NEW] Direct Manager Link ---
  directManagerId  String?
  directManager    DirectManager? @relation(fields: [directManagerId], references: [id])

  // --- [EXISTING] Status & Meta (UNCHANGED) ---
  invitationStatus Boolean   @default(true)
  employmentStatus EmploymentStatus @default(PENDING)
  profileStatus    ProfileStatus    @default(PENDING)
  lastActiveAt     DateTime?
  dateOfJoining    DateTime?
  dateOfLeaving    DateTime?
  statusNote       String?
  isDeleted        Boolean @default(false)
  createdBy        String?
  updatedBy        String?
  lastLoginIp      String?

  deletedAt        DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  services         ServiceEmployee[]
  assignedServices AppointmentService[]
  bundleMembers    BundleMember[]
  timeOffRequests  TimeOffRequest[]
}

model DirectManager {
  id              String   @id @default(uuid())
  name            String   
  lastAccessAt    DateTime @default(now())
  permits         String   @default("All")
  employees       EmployeeProfile[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model EmployeeLanguage {
  id         String          @id @default(uuid())
  name       String          
  level      String          
  employeeId String
  employee   EmployeeProfile @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model SocialConnection {
  id           String          @id @default(uuid())
  platform     String          
  status       String          @default("Not Connected") 
  employeeId   String
  employee     EmployeeProfile @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}


enum EmploymentStatus {
  PENDING
  ACTIVE
  ON_LEAVE
  INACTIVE
}

model AccountantProfile {
  id            String @id @default(uuid())
  userId        String @unique
  user          User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  licenseNumber String?
  deletedAt     DateTime?

  salonId       String  // The Salon ID this AccountantProfile belongs to
  salon         Salon   @relation(fields: [salonId], references: [id], onDelete: Cascade)  // Reverse relation to Salon

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}


// -------------------------------------------------------------------------
// APPOINTMENT
// -------------------------------------------------------------------------

model Appointment {
  id           String        @id @default(uuid())
  salonId      String
  salon        Salon         @relation(fields: [salonId], references: [id])

  clientId     String
  client       User          @relation("MainClient", fields: [clientId], references: [id])

  date         DateTime
  note         String?
  status       AppointmentStatus @default(BOOKED)

  participants Participant[]
  receipt      Receipt?
  payment      Payment?
  logs         AppointmentLog[]

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([salonId])
  @@index([clientId])
}


// -------------------------------------------------------------------------
// NEW MODEL: Appointment Activity Log
// -------------------------------------------------------------------------
model AppointmentLog {
  id            String   @id @default(uuid())
  
  // Link to the appointment
  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  // Link to the person who did the action (Admin, Owner, or Employee)
  userId        String?
  user          User?       @relation(fields: [userId], references: [id])

  // Content of the log
  action        String      // e.g., "Confirmed", "Arrived", "Receipt Printed"
  status        AppointmentStatus 
  
  createdAt     DateTime    @default(now()) // This is the "time" shown in your UI list

  @@index([appointmentId])
}


// -------------------------------------------------------------------------
// PARTICIPANT
// -------------------------------------------------------------------------

model Participant {
  id            String   @id @default(uuid())
  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  userId        String?
  user          User?    @relation(fields: [userId], references: [id])

  name          String

  services      AppointmentService[]
}


// -------------------------------------------------------------------------
// APPOINTMENT SERVICE
// -------------------------------------------------------------------------

model AppointmentService {
  id             String      @id @default(uuid())

  participantId  String
  participant    Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  serviceId      String
  service        Service     @relation(fields: [serviceId], references: [id])

  employeeId     String?
  employee       EmployeeProfile? @relation(fields: [employeeId], references: [id])

  priceAtBooking Decimal     @db.Decimal(10, 2)

  // ✅ Updated time handling (your diagram)
  startAt        DateTime
  endAt          DateTime
}

// -------------------------------------------------------------------------
// PAYMENT
// -------------------------------------------------------------------------

model Payment {
  id              String        @id @default(uuid())


  appointmentId   String?       @unique
  appointment     Appointment?  @relation(fields: [appointmentId], references: [id], onDelete: Cascade)


  voucherPurchase VoucherPurchase?

  amount          Decimal       @db.Decimal(10, 2)
  discount        Decimal       @default(0) @db.Decimal(10, 2)
  tax             Decimal       @default(0) @db.Decimal(10, 2)
  total           Decimal       @db.Decimal(10, 2)

  currency        String        @default("EUR")

  method          PaymentMethod
  status          PaymentStatus @default(PENDING)

  iban            String?
  reference       String?       @unique
  providerTransactionId String?

  paidAt          DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  receiptId       String?       @unique
  receipt         Receipt?      @relation(fields: [receiptId], references: [id])     
}


// -------------------------------------------------------------------------
// ENUMS
// -------------------------------------------------------------------------

enum AppointmentStatus {
  BOOKED
  STARTED
  CONFIRMED
  CANCELLED
  COMPLETED
  ARRIVED
  PAID
}

enum PaymentMethod {
  PAY_IN_SALON
  CARD
  APPLE_PAY
  GOOGLE_PAY
  BANK_TRANSFER
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}


// -------------------------------------------------------------------------
//                                 VOUCHER
// -------------------------------------------------------------------------

model Voucher {
  id          String   @id @default(uuid())

  salonId     String
  salon       Salon    @relation(fields: [salonId], references: [id], onDelete: Cascade)

  title       String
  subtitle    String?

  value       Decimal  @db.Decimal(10,2)
  price       Decimal  @db.Decimal(10,2)

  discountPercent Int?
  description String?

  validityDays Int

  imageUrl    String?
  theme       String?

  isActive    Boolean @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  purchases   VoucherPurchase[]

  @@index([salonId])
  @@index([isActive])
}

model VoucherPurchase {
  id        String   @id @default(uuid())

  voucherId String
  voucher   Voucher  @relation(fields: [voucherId], references: [id], onDelete: Cascade)

  salonId   String
  salon     Salon    @relation(fields: [salonId], references: [id], onDelete: Cascade)

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  code            String   @unique
  senderName      String
  recipientName   String
  recipientEmail  String
  message         String?

  expiryDate      DateTime
  status          VoucherStatus @default(PENDING)

  // ✅ ONLY HERE define relation
  paymentId       String?  @unique
  payment         Payment? @relation(fields: [paymentId], references: [id])

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

enum VoucherStatus {
  PENDING
  PAID
  CANCELLED
  EXPIRED
}


// -------------------------------------------------------------------------
// CONTACT MESSAGE / SEND MESSAGE TO SALON
// -------------------------------------------------------------------------

model ContactMessage {
  id        String        @id @default(uuid())
  
  // Link to the specific salon being contacted
  salonId   String
  salon     Salon         @relation(fields: [salonId], references: [id], onDelete: Cascade)

  // Link to user if they are logged in (Optional)
  userId    String?
  user      User?         @relation(fields: [userId], references: [id])

  // Form fields from your UI
  name      String
  email     String
  subject   String
  message   String        @db.Text

  status    MessageStatus @default(UNREAD)
  
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([salonId])
  @@index([email])
}

enum MessageStatus {
  UNREAD
  READ
  ARCHIVED
  REPLIED
}


// -------------------------------------------------------------------------
// RECEIPT & RECEIPT ITEM
// -------------------------------------------------------------------------

model Receipt {
  id              String        @id @default(uuid())
  salonId         String
  salon           Salon         @relation(fields: [salonId], references: [id], onDelete: Cascade)

  userId          String?
  user            User?         @relation(fields: [userId], references: [id])

  appointmentId   String?       @unique
  appointment     Appointment?  @relation(fields: [appointmentId], references: [id])

  receiptNumber   String        // e.g., #001
  clientName      String
  clientEmail     String?
  
  subTotal        Decimal       @db.Decimal(12, 2)
  taxAmount       Decimal       @db.Decimal(12, 2)
  totalAmount     Decimal       @db.Decimal(12, 2)
  
  method          PaymentMethod @default(PAY_IN_SALON)
  status          ReceiptStatus @default(ISSUED)
  isIndependent   Boolean       @default(false)
  
  items           ReceiptItem[]
  payment         Payment?

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?

  @@index([salonId])
  @@index([receiptNumber])
}

model ReceiptItem {
  id           String   @id @default(uuid())
  receiptId    String
  receipt      Receipt  @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  
  description  String
  quantity     Int      @default(1)
  unitPrice    Decimal  @db.Decimal(12, 2)
  vatRate      Decimal  @db.Decimal(5, 2)
  
  createdAt    DateTime @default(now())
}

enum ReceiptStatus {
  DRAFT
  ISSUED
  PAID
  CANCELLED
  REFUNDED
}


// -------------------------------------------------------------------------
// BUNDLES (NEW MODELS)
// -------------------------------------------------------------------------

enum BundleScheduleType {
  BOOKED_IN_SEQUENCE
  BOOKED_IN_PARALLEL
}

enum BundleCategory {
  REGULAR
  PROMOTION
}

enum BundlePriceType {
  FIXED
  PERCENTAGE_DISCOUNT
}

model Bundle {
  id              String             @id @default(uuid())
  salonId         String
  salon           Salon              @relation(fields: [salonId], references: [id], onDelete: Cascade)

  name            String
  category        BundleCategory     @default(REGULAR)
  description     String?            @db.Text
  
  priceType       BundlePriceType    @default(FIXED)
  price           Decimal            @db.Decimal(10, 2)
  duration        Int                
  
  scheduleType    BundleScheduleType @default(BOOKED_IN_SEQUENCE)
  addToOnlineBook Boolean            @default(true)
  
  isActive        Boolean            @default(true)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  // Relationships
  services        BundleService[]
  members         BundleMember[]
  
  @@index([salonId])
}

// Junction table for Bundle ↔ Service
model BundleService {
  id        String   @id @default(uuid())
  bundleId  String
  serviceId String

  bundle    Bundle   @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([bundleId, serviceId])
}

// Junction table for Bundle ↔ EmployeeProfile
model BundleMember {
  id         String          @id @default(uuid())
  bundleId   String
  employeeId String

  bundle     Bundle          @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  employee   EmployeeProfile @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([bundleId, employeeId])
}


model TimeOffRequest {
  id              String          @id @default(uuid())
  employeeId      String
  employee        EmployeeProfile @relation(fields: [employeeId], references: [id])
  
  type            String          // e.g., "Annual Leave", "Sick Leave"
  startDate       DateTime
  endDate         DateTime
  startTime       String?         // e.g., "09:00"
  endTime         String?         // e.g., "18:00"
  
  repeat          Boolean         @default(false)
  repeatFrequency RepeatFrequency? 
  
  description     String?
  status          String          @default("APPROVED") // or PENDING
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

enum RepeatFrequency {
  DAILY
  WEEKLY
  EVERY_2_WEEKS
  MONTHLY
  QUARTERLY
  YEARLY
}